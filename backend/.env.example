# Copy this file to .env in the backend/ folder and fill in your values.

# ---- MySQL Database ----
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=smart_traffic_db

# ---- Auth ----
JWT_SECRET_KEY=replace-with-a-long-random-secret-string
JWT_EXPIRE_MINUTES=120

# ---- Generative AI (optional) ----
# Leave blank to use the built-in offline scenario generator.
OPENAI_API_KEY=

# ---- Frontend CORS ----
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
